# OpenAI
OPENAI_API_KEY=sk-...
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o

# Memgraph (runs via Docker)
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_USERNAME=
MEMGRAPH_PASSWORD=

# ChromaDB (runs via Docker or in-process)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=privacy_regulations

# GraphRAG Settings
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_VECTOR=5
TOP_K_GRAPH=5
RRF_K=60
MAX_CONTEXT_TOKENS=6000
