# Local LLM (via Ollama - run `ollama pull llama3.1:8b` first, no API key needed)
OLLAMA_MODEL=llama3.1:8b

# Embeddings (runs locally via sentence-transformers, no API key needed)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Memgraph (runs via Docker - credentials must match docker-compose.yml)
MEMGRAPH_HOST=localhost
MEMGRAPH_PORT=7687
MEMGRAPH_USERNAME=memgraph
MEMGRAPH_PASSWORD=memgraph

# ChromaDB (runs via Docker or in-process)
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=privacy_regulations

# GraphRAG Settings
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K_VECTOR=5
TOP_K_GRAPH=5
RRF_K=60
MAX_CONTEXT_TOKENS=6000
